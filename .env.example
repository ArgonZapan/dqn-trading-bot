# DQN Trading Bot Configuration

# Binance API (opcjonalne dla paper trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram (dla powiadomień)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (opcjonalne - dla alertów email/SMS)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Server
PORT=3000

# Agent
EPSILON_START=1.0
EPSILON_END=0.01
EPSILON_DECAY=0.995
GAMMA=0.99
LEARNING_RATE=0.0005
BUFFER_SIZE=10000
BATCH_SIZE=32

# Model Persistence
MODEL_SAVE_INTERVAL_MS=600000

# Sentiment Analysis
SENTIMENT_ENABLED=true
SENTIMENT_REFRESH_INTERVAL=300
SENTIMENT_TWITTER_API_KEY=
SENTIMENT_NEWS_API_KEY=

# Grid Trading Strategy (when STRATEGY=grid)
GRID_SIZE=50
GRID_COUNT=5
GRID_SPACING=absolute

# ML Features (Pattern Recognition, Price Prediction, Anomaly Detection)
ML_FEATURES_ENABLED=true
ML_ANOMALY_THRESHOLD=3
