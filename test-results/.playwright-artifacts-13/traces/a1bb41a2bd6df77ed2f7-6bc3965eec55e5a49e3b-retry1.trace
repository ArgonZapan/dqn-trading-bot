{"type":"frame-snapshot","snapshot":{"callId":"call@8","snapshotName":"after@call@8","pageId":"page@11dfe1f6bcfd62f7aa58b35246822a4e","frameId":"frame@48b614d3ab8fae13588d03a5698922ec","frameUrl":"http://localhost:3000/","doctype":"html","html":["HTML",{"lang":"pl"},["HEAD",{},["BASE",{"href":"http://localhost:3000/"}],"\n",["META",{"charset":"utf-8"}],"\n",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0"}],"\n",["TITLE",{},"DQN Trading Dashboard"],"\n",["LINK",{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap","rel":"stylesheet"}],"\n",["STYLE",{},"\n*{margin:0;padding:0;box-sizing:border-box}\n:root{\n--bg:#0d1117;\n--bg2:#161b22;\n--bg3:#1c2128;\n--border:#30363d;\n--text:#c9d1d9;\n--text2:#8b949e;\n--green:#3fb950;\n--red:#f85149;\n--blue:#58a6ff;\n--orange:#f0883e;\n--purple:#a371f7;\n}\nbody{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}\n.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:24px 32px;display:flex;justify-content:space-between;align-items:center}\n.header h1{font-size:1.4rem;font-weight:700;color:var(--blue)}\n.header h1 span{color:var(--text2);font-weight:400;font-size:.9rem}\n.status-dot{width:10px;height:10px;background:var(--green);border-radius:50%;display:inline-block;margin-right:8px;animation:pulse 2s infinite}\n@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}\n.main{padding:24px;max-width:1400px;margin:0 auto}\n.grid{display:grid;grid-template-columns:1fr 300px;gap:20px}\n.card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;overflow:hidden}\n.card-header{padding:16px 20px;background:var(--bg3);border-bottom:1px solid var(--border);font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text2);display:flex;align-items:center;gap:8px}\n.card-body{padding:20px}\n.prices{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}\n.price-card{background:var(--bg);border-radius:12px;padding:20px;text-align:center;transition:transform .2s,box-shadow .2s;border:1px solid transparent}\n.price-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.4)}\n.price-card.btc{border-color:rgba(247,147,26,.3)}\n.price-card.eth{border-color:rgba(98,126,234,.3)}\n.price-card.sol{border-color:rgba(20,241,149,.3)}\n.price-label{font-size:.7rem;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}\n.price-value{font-size:1.5rem;font-weight:700}\n.price-change{font-size:.8rem;margin-top:6px;font-weight:500}\n.up{color:var(--green)}\n.down{color:var(--red)}\n.metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}\n.metric-box{background:var(--bg);border-radius:10px;padding:16px}\n.metric-label{font-size:.65rem;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}\n.metric-value{font-size:1.3rem;font-weight:700}\n.big-num{font-size:1.8rem;font-weight:700}\n.bar-container{background:var(--bg);border-radius:8px;height:8px;margin-top:12px;overflow:hidden}\n.bar{height:100%;border-radius:8px;transition:width .5s ease}\n.bar.green{background:linear-gradient(90deg,var(--green),#2ea043)}\n.bar.blue{background:linear-gradient(90deg,var(--blue),#1f6feb)}\n.btn{background:linear-gradient(135deg,var(--green),#2ea043);color:#fff;border:none;padding:16px 24px;border-radius:12px;cursor:pointer;width:100%;font-size:.9rem;font-weight:600;transition:all .2s;text-transform:uppercase;letter-spacing:1px}\n.btn:hover{transform:scale(1.02);box-shadow:0 4px 12px rgba(63,185,80,.3)}\n.btn.stop{background:linear-gradient(135deg,var(--red),#da3633)}\n.btn.stop:hover{box-shadow:0 4px 12px rgba(248,81,73,.3)}\n.logs{background:var(--bg);border-radius:12px;padding:16px;height:140px;overflow-y:auto;font-family:'SF Mono',Monaco,monospace;font-size:.7rem}\n.log-entry{margin-bottom:6px;padding:6px 10px;border-radius:6px}\n.log-entry.info{background:rgba(139,148,158,.1);color:var(--text2)}\n.log-entry.buy{background:rgba(63,185,80,.15);color:var(--green)}\n.log-entry.sell{background:rgba(248,81,73,.15);color:var(--red)}\n.log-entry.system{background:rgba(88,166,255,.1);color:var(--blue)}\n.history-row{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--bg);border-radius:8px;font-size:.7rem;cursor:pointer;transition:background .15s}\n.history-row:hover{background:var(--bg3)}\n.history-row .ep{color:var(--blue);font-weight:600;min-width:40px}\n.history-row .pnl{font-weight:600;min-width:60px}\n.history-row .pnl.pos{color:var(--green)}\n.history-row .pnl.neg{color:var(--red)}\n.history-row .stats{color:var(--text2);flex:1;font-size:.65rem}\n.history-row .dd{color:var(--orange);font-size:.65rem;min-width:50px;text-align:right}\n.chart-placeholder{background:var(--bg);border-radius:12px;height:200px;display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:.8rem;border:1px dashed var(--border)}\n@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}\n.card{animation:fadeIn .3s ease}\n/* Mobile Responsive - Enhanced */\n/* ========== RESPONSIVE BREAKPOINTS ========== */\n/* Mobile: < 768px | Tablet: 768px-1024px | Desktop: > 1024px */\n\n/* TABLET - 768px to 1024px */\n@media(max-width:1024px){\n  .grid{grid-template-columns:1fr 280px}\n  .header{padding:20px 24px}\n  .header h1{font-size:1.2rem}\n  .main{padding:20px}\n  .prices{grid-template-columns:repeat(3,1fr);gap:12px}\n  .price-card{padding:16px}\n  .card-body{padding:16px}\n  .metrics-grid{grid-template-columns:1fr 1fr}\n  #episodeChart,#lastEpisodeChart{height:200px!important}\n  .paper-grid{grid-template-columns:1fr 1fr!important}\n  .paper-stats-grid{grid-template-columns:1fr 1fr}\n  .modal-stats{grid-template-columns:repeat(3,1fr)}\n}\n\n/* MOBILE - < 768px - Primary breakpoint */\n@media(max-width:768px){\n  .grid{display:flex;flex-direction:column;gap:0;padding-bottom:70px}\n  .grid>div:last-child{order:-1;margin-bottom:0}\n  .prices{display:grid;grid-template-columns:1fr 1fr;gap:10px}\n  .price-card{padding:14px;min-height:80px;display:flex;flex-direction:column;justify-content:center}\n  .price-label{font-size:.6rem;margin-bottom:4px}\n  .price-value{font-size:1.1rem}\n  .price-change{font-size:.7rem;margin-top:4px}\n  .header{padding:14px 16px;flex-wrap:wrap;gap:10px}\n  .header h1{font-size:1rem}\n  .header h1 span{display:none}\n  .header>div:last-child{align-self:center;margin-top:0}\n  .main{padding:12px}\n  .card{border-radius:12px;margin-top:12px}\n  .card-header{padding:10px 14px;font-size:.65rem}\n  .card-body{padding:14px}\n  .metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}\n  .metric-box{padding:12px}\n  .metric-label{font-size:.6rem}\n  .metric-value{font-size:1rem}\n  .big-num{font-size:1.3rem}\n  #episodeChart,#lastEpisodeChart{height:180px!important}\n  .chart-placeholder{height:160px}\n  .logs{height:90px;font-size:.65rem}\n  .btn{min-height:44px;padding:12px 16px;font-size:.8rem;border-radius:10px}\n  .modal-content{width:97%;max-height:88vh;border-radius:16px}\n  .modal-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px}\n  .modal-stat{padding:12px}\n  .modal-stat .value{font-size:1rem}\n  /* Sidebar cards - stack on mobile */\n  .sidebar-cards{display:flex;flex-direction:column;gap:12px}\n  .sidebar-cards .card{margin-top:0}\n  /* Paper trading mobile */\n  .paper-grid{grid-template-columns:1fr!important;gap:8px}\n  .paper-stats-grid{grid-template-columns:1fr 1fr}\n  .paper-toggle-row{flex-direction:column;align-items:flex-start!important;gap:8px}\n  .paper-toggle-row>div{width:100%}\n  #paperStrategy,#paperSL,#paperTP{font-size:.75rem;padding:10px}\n  /* Agent metrics */\n  #trainingTimer{font-size:1.8rem}\n  /* History rows */\n  .history-row{flex-wrap:wrap;gap:4px;padding:10px 12px}\n  .history-row .stats{width:100%;order:3;margin-top:4px}\n}\n\n/* ========== STICKY BOTTOM NAVIGATION ========== */\n.bottom-nav {\n  display: flex !important;\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  z-index: 999;\n  background: var(--bg2);\n  border-top: 1px solid var(--border);\n  padding: 0;\n  box-shadow: 0 -4px 16px rgba(0,0,0,0.4);\n}\n\n.bottom-nav-item {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 4px;\n  padding: 10px 4px;\n  background: none;\n  border: none;\n  color: var(--text2);\n  font-size: .6rem;\n  cursor: pointer;\n  transition: color .2s;\n  min-height: 56px;\n  -webkit-tap-highlight-color: transparent;\n  touch-action: manipulation;\n}\n\n.bottom-nav-item svg {\n  width: 22px;\n  height: 22px;\n  stroke-width: 1.8;\n}\n\n.bottom-nav-item.active {\n  color: var(--blue);\n}\n\n.bottom-nav-item:active {\n  background: rgba(88,166,255,0.1);\n}\n\n.bottom-nav-item:focus {\n  outline: none;\n}\n\n/* ========== TOUCH-FRIENDLY IMPROVEMENTS ========== */\nbutton, .btn, input, select, .switch, .slider, .history-row, .modal-close {\n  touch-action: manipulation;\n  -webkit-tap-highlight-color: transparent;\n}\n\nbutton, .bottom-nav-item, .history-row, .card-header {\n  user-select: none;\n  -webkit-user-select: none;\n}\n\n.main, .logs, .modal-body, #paperHistorySection {\n  -webkit-overflow-scrolling: touch;\n  overflow-y: auto;\n}\n\ncanvas {\n  max-width: 100%;\n  height: auto !important;\n}\n\n.modal-close {\n  min-width: 44px;\n  min-height: 44px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 8px 16px;\n  cursor: pointer;\n}\n\n.switch {\n  min-width: 44px;\n  min-height: 24px;\n}\n\n.switch input:checked + .slider {\n  background: var(--green);\n  border-color: var(--green);\n}\n\ninput[type=\"number\"], input[type=\"text\"], select {\n  min-height: 44px;\n  touch-action: manipulation;\n}\n\n/* Remove number input spinners on mobile */\ninput[type=\"number\"]::-webkit-inner-spin-button,\ninput[type=\"number\"]::-webkit-outer-spin-button {\n  -webkit-appearance: none;\n  margin: 0;\n}\ninput[type=\"number\"] {\n  -moz-appearance: textfield;\n}\n\n/* Touch feedback for buttons */\n.btn:active, .bottom-nav-item:active {\n  transform: scale(0.97);\n  transition: transform .1s;\n}\n\n/* Swipe hint - desktop hidden, mobile only */\n.swipe-hint{display:none}\n@media(max-width:768px){\n  .swipe-hint{display:inline}\n  canvas{max-width:600px!important}\n}\n\n/* SMALL MOBILE - < 480px */\n@media(max-width:480px){\n  .prices{grid-template-columns:1fr 1fr;gap:8px}\n  .price-card{min-height:70px;padding:12px}\n  .price-label{font-size:.55rem}\n  .price-value{font-size:1rem;font-weight:600}\n  .card{border-radius:10px;margin-top:10px}\n  .card-header{padding:8px 12px;font-size:.6rem}\n  .card-body{padding:12px}\n  .metrics-grid{grid-template-columns:1fr;gap:8px}\n  .metric-box{padding:10px}\n  #episodeChart,#lastEpisodeChart{height:160px!important}\n  .chart-placeholder{height:150px;font-size:.7rem}\n  .btn{min-height:44px;padding:10px 14px;font-size:.75rem}\n  .logs{height:80px;font-size:.6rem}\n  .log-entry{padding:4px 8px}\n  #trainingTimer{font-size:1.5rem}\n  /* Paper trading very small */\n  .paper-stats-grid{grid-template-columns:1fr 1fr;gap:6px}\n  /* Live trading mobile */\n  #liveTradingCard .card-body{padding:12px}\n  #livePositionSection .card-body{padding:10px}\n  /* SL/TP inputs - 3-col grid on tablet, stack on mobile */\n  .live-sl-tp-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:12px}\n  .live-sl-tp-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px}\n  .live-sl-tp-item label{display:block;font-size:.55rem;color:var(--text2);text-transform:uppercase;margin-bottom:4px}\n  .live-sl-tp-item input{width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:4px 4px;border-radius:4px;font-size:.8rem;font-weight:600;min-height:40px}\n  /* LONG/SHORT buttons - full width row */\n  .live-trade-btns{display:flex;gap:8px;margin-bottom:12px}\n  .live-trade-btns .btn{flex:1;min-height:48px;font-size:.85rem!important;font-weight:700;padding:12px!important}\n  /* Paper SL/TP row */\n  .paper-sltp-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}\n  .paper-sltp-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px}\n  .paper-sltp-item label{display:block;font-size:.55rem;color:var(--text2);text-transform:uppercase;margin-bottom:4px}\n  .paper-sltp-item input{width:100%;min-height:40px}\n  .live-sl-tp-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}\n  .live-sl-tp-grid .sl-tp-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px}\n  .live-sl-tp-grid .sl-tp-item label{display:block;font-size:.6rem;color:var(--text2);text-transform:uppercase;margin-bottom:4px}\n  #liveSL,#liveTP,#livePositionSize{width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:4px 6px;border-radius:4px;font-size:.8rem;font-weight:600;min-height:44px}\n  .live-btn-row{display:flex;gap:8px;margin-bottom:12px}\n  .live-btn-row .btn{flex:1;min-height:48px;font-size:.85rem!important;font-weight:700}\n  /* Paper SL/TP mobile */\n  .paper-sltp-row{display:flex;gap:8px;margin-bottom:12px}\n  .paper-sltp-row .paper-sltp-item{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px}\n  .paper-sltp-item label{display:block;font-size:.6rem;color:var(--text2);text-transform:uppercase;margin-bottom:4px}\n  #paperSL,#paperTP{width:100%;min-height:44px}\n  /* Modal adjustments */\n  .modal-header{padding:14px 16px}\n  .modal-body{padding:16px}\n  .modal-stats{grid-template-columns:1fr 1fr;gap:6px}\n  .modal-trade{grid-template-columns:28px 1fr 60px 60px;padding:8px 12px;font-size:.7rem}\n}\n\n/* EXTRA SMALL - < 360px */\n@media(max-width:360px){\n  .header h1{font-size:.9rem}\n  .prices{grid-template-columns:1fr;gap:6px}\n  .price-card{min-height:60px}\n  .metric-value{font-size:.9rem}\n  .btn{font-size:.7rem;padding:8px 12px}\n  #trainingTimer{font-size:1.3rem}\n}\n/* Episode Detail Modal */\n#episodeModal{display:none;position:fixed;inset:0;z-index:1000;align-items:center;justify-content:center;background:rgba(0,0,0,.7);backdrop-filter:blur(4px)}\n#episodeModal.open{display:flex}\n.modal-content{background:var(--bg2);border:1px solid var(--border);border-radius:20px;width:90%;max-width:600px;max-height:80vh;overflow:hidden;display:flex;flex-direction:column;animation:modalSlide .25s ease}\n@keyframes modalSlide{from{opacity:0;transform:scale(.95) translateY(-20px)}to{opacity:1;transform:scale(1) translateY(0)}}\n.modal-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;background:var(--bg3);border-bottom:1px solid var(--border)}\n.modal-header h2{font-size:1rem;font-weight:700;margin:0}\n.modal-close{background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:8px;padding:6px 14px;cursor:pointer;font-size:.8rem}\n.modal-close:hover{background:var(--bg3)}\n.modal-body{padding:24px;overflow-y:auto}\n.modal-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}\n.modal-stat{background:var(--bg);border-radius:12px;padding:14px;text-align:center}\n.modal-stat .label{font-size:.65rem;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}\n.modal-stat .value{font-size:1.1rem;font-weight:700}\n.modal-stat .value.pos{color:var(--green)}\n.modal-stat .value.neg{color:var(--red)}\n.modal-trades{border:1px solid var(--border);border-radius:12px;overflow:hidden}\n.modal-trade{display:grid;grid-template-columns:32px 1fr 80px 80px;padding:10px 16px;gap:12px;font-size:.75rem;border-bottom:1px solid var(--border);align-items:center}\n.modal-trade:last-child{border-bottom:none}\n.modal-trade.header{background:var(--bg3);color:var(--text2);font-size:.65rem;text-transform:uppercase;letter-spacing:.5px}\n.modal-trade .buy{color:var(--green)}\n.modal-trade .sell{color:var(--red)}\n.paper-badge{display:inline-block;background:linear-gradient(135deg,#f0883e,#b35900);color:#fff;font-size:.5rem;font-weight:700;padding:2px 5px;border-radius:6px;text-transform:uppercase;letter-spacing:.5px;vertical-align:middle;margin-left:4px}\n.transaction-badge{display:inline-block;background:var(--bg3);color:var(--text2);font-size:.55rem;font-weight:600;padding:2px 6px;border-radius:8px;text-transform:uppercase;letter-spacing:.5px;margin-left:6px;border:1px solid var(--border)}\n.transaction-badge.paper{background:linear-gradient(135deg,rgba(240,136,62,.2),rgba(179,89,0,.2));color:#f0883e;border-color:rgba(240,136,62,.4)}\n.transaction-badge.live{background:linear-gradient(135deg,rgba(63,185,80,.2),rgba(46,160,67,.2));color:var(--green);border-color:rgba(63,185,80,.4)}\n.modal-trade .empty{text-align:center;color:var(--text2);padding:20px}\n"],"\n"],"\n",["BODY",{},"\n",["DIV",{"class":"header"},"\n",["DIV",{},"\n",["H1",{},"🤖 DQN Trading ",["SPAN",{},"Dashboard"]],"\n"],"\n",["DIV",{"style":"display:flex;align-items:center;gap:16px"},"\n",["SPAN",{"class":"status-dot"}],"\n",["SPAN",{"style":"font-size:.8rem;color:var(--text2)","id":"modeLabel"},"Live"],"\n",["BUTTON",{"id":"langToggle","onclick":"","style":"background:var(--bg);border:1px solid var(--border);color:var(--text2);padding:4px 8px;border-radius:6px;font-size:.6rem;cursor:pointer"},"PL"],["SPAN",{"id":"paperModeBadge","style":"display:none;background:linear-gradient(135deg,#f0883e,#b35900);color:#fff;font-size:.6rem;font-weight:700;padding:3px 8px;border-radius:10px;text-transform:uppercase;letter-spacing:.5px"},"📄 PAPER"],"\n"],"\n"],"\n",["DIV",{"class":"main"},"\n",["DIV",{"class":"grid"},"\n",["DIV",{"id":"tab-training","class":"tab-section","style":"display:block"},"\n",["DIV",{},"\n",["DIV",{"class":"card"},"\n",["DIV",{"class":"card-header","data-i18n":"livePrices"},"Ceny na zywo"],"\n",["DIV",{"class":"card-body"},"\n",["DIV",{"c