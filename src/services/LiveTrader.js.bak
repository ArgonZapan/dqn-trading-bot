/**
 * Live Trading Module - Real Binance API integration
 * Requires BINANCE_API_KEY and BINANCE_API_SECRET in .env
 * 
 * WARNING: Real money at risk. Use with caution.
 * Paper trading is recommended before going live.
 */

import { Candle } from '../types';

const BASE_URL = 'https://api.binance.com';
const SIGNATURE_METHOD = 'SHA-256';

export interface LivePosition {
  id: string;
  side: 'LONG' | 'SHORT';
  symbol: string;
  quantity: number;
  entryPrice: number;
  stopLoss: number;
  takeProfit: number;
  orderId: number;        // Binance order ID for SL/TP
  slOrderId: number;      // Binance order ID for SL
  tpOrderId: number;      // Binance order ID for TP
  entryTime: number;
}

export interface LiveTrade {
  id: string;
  orderId: number;
  side: 'BUY' | 'SELL';
  symbol: string;
  price: number;
  quantity: number;
  fee: number;
  pnl?: number;
  timestamp: number;
}

export interface LiveTradingStats {
  enabled: boolean;
  mode: 'live' | 'paper';
  symbol: string;
  capital: number;
  positions: LivePosition[];
  closedTrades: LiveTrade[];
  stats: {
    totalTrades: number;
    winningTrades: number;
    losingTrades: number;
    winRate: number;
    totalPnl: number;
    totalFees: number;
    profitFactor: number;
    maxDrawdown: number;
    maxDrawdownPercent: number;
    avgWin: number;
    avgLoss: number;
    sharpeRatio: number;
    currentStreak: number;
    bestStreak: number;
    worstStreak: number;
  };
}

export interface LiveConfig {
  apiKey: string;
  apiSecret: string;
  symbol: string;
  positionSize: number;     // 0.1 - 1.0 (% of capital per trade)
  stopLossPercent: number; // e.g. 2.0 = 2% SL
  takeProfitPercent: number;
  leverage: number;         // 1-125 for futures (spot = 1)
  testMode: boolean;        // If true, only simulate orders
}

/**
 * Create HMAC-SHA256 signature for Binance API
 */
async function hmacSign(queryString: string, secret: string): Promise<string> {
  const crypto = await import('crypto');
  return crypto.createHmac('sha256', secret)
    .update(queryString)
    .digest('hex');
}

/**
 * Build signed query string for Binance API
 */
async function buildSignedParams(params: Record<string, string | number>, apiSecret: string): Promise<string> {
  const timestamp = Date.now();
  const queryParams = { ...params, timestamp };
  const queryString = Object.entries(queryParams)
    .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
    .join('&');
  const signature = await hmacSign(queryString, apiSecret);
  return `${queryString}&signature=${signature}`;
}

/**
 * LiveTrader - Real order execution on Binance
 */
export class LiveTrader {
  private apiKey: string = '';
  private apiSecret: string = '';
  private symbol: string = 'BTCUSDT';
  private positionSize: number = 0.95;
  private stopLossPercent: number = 2.0;
  private takeProfitPercent: number = 4.0;
  private testMode: boolean = true; // Default to test mode for safety
  
  private enabled: boolean = false;
  private mode: 'live' | 'paper' = 'paper';
  private positions: Map<string, LivePosition> = new Map();
  private closedTrades: LiveTrade[] = [];
  
  private capital: number = 0;
  private baseCapital: number = 1000; // Initial capital for tracking
  
  private feeRate: number = 0.001; // 0.1% spot fee
  private peakBalance: number = 1000;
  private maxDrawdown: number = 0;
  private maxDrawdownPercent: number = 0;

  private priceInterval: any = null;
  private currentPrice: number = 0;
  private priceCallbacks: ((price: number) => void)[] = [];

  constructor(config?: Partial<LiveConfig>) {
    if (config) {
      this.configure(config);
    }
  }

  /**
   * Configure the trader with API keys and settings
   */
  configure(config: Partial<LiveConfig>) {
    if (config.apiKey) this.apiKey = config.apiKey;
    if (config.apiSecret) this.apiSecret = config.apiSecret;
    if (config.symbol) this.symbol = config.symbol;
    if (config.positionSize) this.positionSize = config.positionSize;
    if (config.stopLossPercent) this.stopLossPercent = config.stopLossPercent;
    if (config.takeProfitPercent) this.takeProfitPercent = config.takeProfitPercent;
    if (config.testMode !== undefined) this.testMode = config.testMode;
  }

  /**
   * Check if API keys are configured
   */
  isConfigured(): boolean {
    return !!(this.apiKey && this.apiSecret);
  }

  /**
   * Check if running in test mode
   */
  isTestMode(): boolean {
    return this.testMode;
  }

  /**
   * Enable live trading
   */
  async enable(testMode: boolean = true): Promise<void> {
    this.testMode = testMode;
    
    if (!this.isConfigured()) {
      throw new Error('API keys not configured. Set BINANCE_API_KEY and BINANCE_API_SECRET');
    }

    // Fetch initial balances
    const balances = await this.fetchBalances();
    const usdtBalance = balances.find(b => b.asset === 'USDT');
    this.capital = usdtBalance ? usdtBalance.free : 0;
    this.baseCapital = this.capital || 1000;
    this.peakBalance = this.capital || 1000;

    this.enabled = true;
    this.mode = testMode ? 'paper' : 'live';
    this.positions.clear();
    this.closedTrades = [];
    
    // Start price updates
    this.startPriceUpdates();
  }

  /**
   * Disable live trading
   */
  disable(): void {
    this.enabled = false;
    this.mode = 'paper';
    this.stopPriceUpdates();
  }

  isEnabled(): boolean {
    return this.enabled;
  }

  getMode(): 'live' | 'paper' {
    return this.mode;
  }

  getSymbol(): string {
    return this.symbol;
  }

  setSymbol(symbol: string): void {
    this.symbol = symbol;
  }

  setStopLoss(percent: number): void {
    this.stopLossPercent = Math.max(0.1, Math.min(50, percent));
  }

  setTakeProfit(percent: number): void {
    this.takeProfitPercent = Math.max(0.1, Math.min(100, percent));
  }

  setPositionSize(size: number): void {
    this.positionSize = Math.max(0.01, Math.min(1.0, size));
  }

  /**
   * Subscribe to price updates
   */
  onPrice(cb: (price: number) => void): () => void {
    this.priceCallbacks.push(cb);
    return () => { this.priceCallbacks = this.priceCallbacks.filter(x => x !== cb); };
  }

  /**
   * Start polling current price
   */
  private startPriceUpdates(): void {
    this.stopPriceUpdates();
    this.priceInterval = setInterval(async () => {
      const price = await this.getCurrentPrice(this.symbol);
      if (price > 0) {
        this.currentPrice = price;
        this.updateUnrealizedPnL();
        this.priceCallbacks.forEach(cb => cb(price));
      }
    }, 2000);
  }

  /**
   * Stop price polling
   */
  private stopPriceUpdates(): void {
    if (this.priceInterval) {
      clearInterval(this.priceInterval);
      this.priceInterval = null;
    }
  }

  /**
   * Get current price from Binance
   */
  async getCurrentPrice(symbol: string = 'BTCUSDT'): Promise<number> {
    try {
      const r = await fetch(`${BASE_URL}/api/v3/ticker/price?symbol=${symbol}`);
      if (!r.ok) return 0;
      const d = await r.json();
      return parseFloat(d.price);
    } catch { return 0; }
  }

  /**
   * Fetch account balances from Binance
   */
  async fetchBalances(): Promise<{ asset: string; free: number; locked: number }[]> {
    if (this.testMode) {
      return [
        { asset: 'USDT', free: this.capital || 1000, locked: 0 },
        { asset: 'BTC', free: 0, locked: 0 }
      ];
    }

    try {
      const params = await buildSignedParams({ symbol: this.symbol }, this.apiSecret);
      const r = await fetch(`${BASE_URL}/api/v3/account?${params}`, {
        headers: { 'X-MBX-APIKEY': this.apiKey }
      });
      if (!r.ok) return [];
      const d = await r.json();
      return (d.balances || []).map((b: any) => ({
        asset: b.asset,
        free: parseFloat(b.free),
        locked: parseFloat(b.locked)
      }));
    } catch { return []; }
  }

  /**
   * Execute a MARKET BUY order
   */
  async marketBuy(quantity: number): Promise<LiveTrade | null> {
    if (!this.enabled) return null;
    
    if (this.testMode) {
      return this.simulateBuy(quantity, this.currentPrice);
    }

    try {
      const params = await buildSignedParams({
        symbol: this.symbol,
        side: 'BUY',
        type: 'MARKET',
        quantity: quantity.toFixed(6)
      }, this.apiSecret);

      const r = await fetch(`${BASE_URL}/api/v3/order`, {
        method: 'POST',
        headers: { 'X-MBX-APIKEY': this.apiKey },
        body: new URLSearchParams(params)
      });

      const d = await r.json();
      if (!r.ok || d.code) {
        console.error('Market buy failed:', d);
        return null;
      }

      const price = parseFloat(d.fills?.[0]?.price || this.currentPrice.toString());
      const fee = parseFloat(d.commission || '0');
      
      const trade: LiveTrade = {
        id: `live_${d.orderId}_buy`,
        orderId: d.orderId,
        side: 'BUY',
        symbol: this.symbol,
        price,
        quantity,
        fee,
        timestamp: Date.now()
      };

      this.closedTrades.push(trade);
      this.capital -= quantity * price + fee;
      return trade;
    } catch (e: any) {
      console.error('Market buy error:', e.message);
      return null;
    }
  }

  /**
   * Execute a MARKET SELL order
   */
  async marketSell(quantity: number): Promise<LiveTrade | null> {
    if (!this.enabled) return null;

    if (this.testMode) {
      return this.simulateSell(quantity, this.currentPrice);
    }

    try {
      const params = await buildSignedParams({
        symbol: this.symbol,
        side: 'SELL',
        type: 'MARKET',
        quantity: quantity.toFixed(6)
      }, this.apiSecret);

      const r = await fetch(`${BASE_URL}/api/v3/order`, {
        method: 'POST',
        headers: { 'X-MBX-APIKEY': this.apiKey },
        body: new URLSearchParams(params)
      });

      const d = await r.json();
      if (!r.ok || d.code) {
        console.error('Market sell failed:', d);
        return null;
      }

      const price = parseFloat(d.fills?.[0]?.price || this.currentPrice.toString());
      const fee = parseFloat(d.commission || '0');

      const trade: LiveTrade = {
        id: `live_${d.orderId}_sell`,
        orderId: d.orderId,
        side: 'SELL',
        symbol: this.symbol,
        price,
        quantity,
        fee,
        timestamp: Date.now()
      };

      this.closedTrades.push(trade);
      this.capital += quantity * price - fee;
      return trade;
    } catch (e: any) {
      console.error('Market sell error:', e.message);
      return null;
    }
  }

  /**
   * Open a LONG position (buy + set SL/TP)
   */
  async openLong(quantity?: number): Promise<LivePosition | null> {
    if (!this.enabled || this.positions.has('LONG')) return null;
    
    const qty = quantity || (this.capital * this.positionSize) / this.currentPrice;
    if (qty * this.currentPrice > this.capital) {
      console.warn('Insufficient capital for long position');
      return null;
    }

    const trade = await this.marketBuy(qty);
    if (!trade) return null;

    const sl = this.currentPrice * (1 - this.stopLossPercent / 100);
    const tp = this.currentPrice * (1 + this.takeProfitPercent / 100);

    const position: LivePosition = {
      id: `live_${Date.now()}`,
      side: 'LONG',
      symbol: this.symbol,
      quantity: qty,
      entryPrice: this.currentPrice,
      stopLoss: sl,
      takeProfit: tp,
      orderId: trade.orderId,
      slOrderId: 0,
      tpOrderId: 0,
      entryTime: Date.now()
    };

    // In live mode, place SL/TP as linked orders
    if (!this.testMode) {
      const slOrder = await this.placeStopLoss('LONG', qty, sl);
      const tpOrder = await this.placeTakeProfit('LONG', qty, tp);
      position.slOrderId = slOrder?.orderId || 0;
      position.tpOrderId = tpOrder?.orderId || 0;
    }

    this.positions.set('LONG', position);
    return position;
  }

  /**
   * Close a LONG position (market sell)
   */
  async closeLong(reason: string = 'MANUAL'): Promise<LiveTrade | null> {
    const pos = this.positions.get('LONG');
    if (!pos) return null;

    // Cancel SL/TP orders if in live mode
    if (!this.testMode && (pos.slOrderId || pos.tpOrderId)) {
      await this.cancelOrder(pos.slOrderId);
      await this.cancelOrder(pos.tpOrderId);
    }

    const trade = await this.marketSell(pos.quantity);
    if (!trade) return null;

    const pnl = (this.currentPrice - pos.entryPrice) * pos.quantity;
    trade.pnl = pnl;

    this.positions.delete('LONG');
    return trade;
  }

  /**
   * Open a SHORT position (sell first, then set SL/TP)
   */
  async openShort(quantity?: number): Promise<LivePosition | null> {
    if (!this.enabled || this.positions.has('SHORT')) return null;

    const qty = quantity || (this.capital * this.positionSize) / this.currentPrice;
    
    // In spot mode, shorting means selling BTC we own
    // This simulates short by treating as inverse position
    if (this.testMode) {
      return this.simulateShort(qty);
    }

    // For spot, short means just sell BTC
    const trade = await this.marketSell(qty);
    if (!trade) return null;

    const sl = this.currentPrice * (1 + this.stopLossPercent / 100);
    const tp = this.currentPrice * (1 - this.takeProfitPercent / 100);

    const position: LivePosition = {
      id: `live_${Date.now()}`,
      side: 'SHORT',
      symbol: this.symbol,
      quantity: qty,
      entryPrice: this.currentPrice,
      stopLoss: sl,
      takeProfit: tp,
      orderId: trade.orderId,
      slOrderId: 0,
      tpOrderId: 0,
      entryTime: Date.now()
    };

    this.positions.set('SHORT', position);
    return position;
  }

  /**
   * Close a SHORT position (buy back)
   */
  async closeShort(reason: string = 'MANUAL'): Promise<LiveTrade | null> {
    const pos = this.positions.get('SHORT');
    if (!pos) return null;

    if (!this.testMode && (pos.slOrderId || pos.tpOrderId)) {
      await this.cancelOrder(pos.slOrderId);
      await this.cancelOrder(pos.tpOrderId);
    }

    // Buy back to close short
    const trade = await this.marketBuy(pos.quantity);
    if (!trade) return null;

    const pnl = (pos.entryPrice - this.currentPrice) * pos.quantity;
    trade.pnl = pnl;

    this.positions.delete('SHORT');
    return trade;
  }

  /**
   * Place a STOP LOSS order on Binance
   */
  private async placeStopLoss(side: 'LONG' | 'SHORT', quantity: number, price: number): Promise<any> {
    if (this.testMode) return null;

    try {
      const params = await buildSignedParams({
        symbol: this.symbol,
        side: side === 'LONG' ? 'SELL' : 'BUY',
        type: 'STOP_LOSS_LIMIT',
        quantity: quantity.toFixed(6),
        stopPrice: price.toFixed(2),
        price: price.toFixed(2),
        timeInForce: 'GTC'
      }, this.apiSecret);

      const r = await fetch(`${BASE_URL}/api/v3/order`, {
        method: 'POST',
        headers: { 'X-MBX-APIKEY': this.apiKey },
        body: new URLSearchParams(params)
      });

      return await r.json();
    } catch { return null; }
  }

  /**
   * Place a TAKE PROFIT order on Binance
   */
  private async placeTakeProfit(side: 'LONG' | 'SHORT', quantity: number, price: number): Promise<any> {
    if (this.testMode) return null;

    try {
      const params = await buildSignedParams({
        symbol: this.symbol,
        side: side === 'LONG' ? 'SELL' : 'BUY',
        type: 'TAKE_PROFIT_LIMIT',
        quantity: quantity.toFixed(6),
        stopPrice: price.toFixed(2),
        price: price.toFixed(2),
        timeInForce: 'GTC'
      }, this.apiSecret);

      const r = await fetch(`${BASE_URL}/api/v3/order`, {
        method: 'POST',
        headers: { 'X-MBX-APIKEY': this.apiKey },
        body: new URLSearchParams(params)
      });

      return await r.json();
    } catch { return null; }
  }

  /**
   * Cancel an order by ID
   */
  private async cancelOrder(orderId: number): Promise<boolean> {
    if (this.testMode || !orderId) return true;

    try {
      const params = await buildSignedParams({
        symbol: this.symbol,
        orderId: orderId.toString()
      }, this.apiSecret);

      const r = await fetch(`${BASE_URL}/api/v3/order`, {
        method: 'DELETE',
        headers: { 'X-MBX-APIKEY': this.apiKey },
        body: new URLSearchParams(params)
      });

      return r.ok;
    } catch { return false; }
  }

  // ─── Simulation methods (test mode) ─────────────────────────────────────

  private simulateBuy(quantity: number, price: number): LiveTrade {
    const fee = quantity * price * this.feeRate;
    const trade: LiveTrade = {
      id: `test_${Date.now()}_buy`,
      orderId: 0,
      side: 'BUY',
      symbol: this.symbol,
      price,
      quantity,
      fee,
      timestamp: Date.now()
    };
    this.closedTrades.push(trade);
    this.capital -= quantity * price + fee;
    return trade;
  }

  private simulateSell(quantity: number, price: number): LiveTrade {
    const fee = quantity * price * this.feeRate;
    const trade: LiveTrade = {
      id: `test_${Date.now()}_sell`,
      orderId: 0,
      side: 'SELL',
      symbol: this.symbol,
      price,
      quantity,
      fee,
      timestamp: Date.now()
    };
    this.closedTrades.push(trade);
    this.capital += quantity * price - fee;
    return trade;
  }

  private simulateShort(quantity: number): LivePosition {
    const entryPrice = this.currentPrice;
    const fee = quantity * entryPrice * this.feeRate;
    
    // "Receive" USDT from selling
    this.capital += quantity * entryPrice - fee;

    const position: LivePosition = {
      id: `test_${Date.now()}`,
      side: 'SHORT',
      symbol: this.symbol,
      quantity,
      entryPrice,
      stopLoss: entryPrice * (1 + this.stopLossPercent / 100),
      takeProfit: entryPrice * (1 - this.takeProfitPercent / 100),
      orderId: 0,
      slOrderId: 0,
      tpOrderId: 0,
      entryTime: Date.now()
    };

    this.positions.set('SHORT', position);
    return position;
  }

  // ─── Position monitoring ─────────────────────────────────────────────────

  private updateUnrealizedPnL(): void {
    for (const [, pos] of this.positions) {
      if (pos.side === 'LONG') {
        pos.entryPrice; // unchanged
      }
    }
  }

  getUnrealizedPnL(): number {
    let pnl = 0;
    for (const [, pos] of this.positions) {
      const currentValue = pos.quantity * this.currentPrice;
      const entryValue = pos.quantity * pos.entryPrice;
      if (pos.side === 'LONG') {
        pnl += currentValue - entryValue;
      } else {
        pnl += entryValue - currentValue;
      }
    }
    return pnl;
  }

  getTotalEquity(): number {
    return this.capital + this.getUnrealizedPnL();
  }

  /**
   * Check and execute SL/TP if triggered
   */
  async checkAndExecuteSLTP(): Promise<void> {
    if (!this.enabled || !this.currentPrice) return;

    for (const [id, pos] of this.positions) {
      let triggered = false;
      let reason = '';

      if (pos.side === 'LONG') {
        if (this.currentPrice <= pos.stopLoss) { triggered = true; reason = 'SL'; }
        else if (this.currentPrice >= pos.takeProfit) { triggered = true; reason = 'TP'; }
      } else if (pos.side === 'SHORT') {
        if (this.currentPrice >= pos.stopLoss) { triggered = true; reason = 'SL'; }
        else if (this.currentPrice <= pos.takeProfit) { triggered = true; reason = 'TP'; }
      }

      if (triggered) {
        console.log(`⚡ ${pos.side} ${reason} triggered @ $${this.currentPrice.toLocaleString()}`);
        if (pos.side === 'LONG') await this.closeLong(reason);
        else await this.closeShort(reason);
      }
    }
  }

  // ─── Stats ─────────────────────────────────────────────────────────────────

  private updatePeakAndDrawdown(): void {
    const equity = this.getTotalEquity();
    if (equity > this.peakBalance) {
      this.peakBalance = equity;
    }
    const dd = this.peakBalance - equity;
    if (dd > this.maxDrawdown) {
      this.maxDrawdown = dd;
      this.maxDrawdownPercent = this.peakBalance > 0 ? (dd / this.peakBalance) * 100 : 0;
    }
  }

  getStats(): LiveTradingStats {
    const closed = this.closedTrades;
    const winning = closed.filter(t => (t.pnl || 0) > 0);
    const losing = closed.filter(t => (t.pnl || 0) <= 0);
    const totalPnl = closed.reduce((s, t) => s + (t.pnl || 0), 0);
    const totalFees = closed.reduce((s, t) => s + t.fee, 0);
    const winRate = closed.length > 0 ? (winning.length / closed.length) * 100 : 0;
    const avgWin = winning.length > 0 ? winning.reduce((s, t) => s + (t.pnl || 0), 0) / winning.length : 0;
    const avgLoss = losing.length > 0 ? losing.reduce((s, t) => s + (t.pnl || 0), 0) / losing.length : 0;
    const profitFactor = totalPnl > 0 && avgLoss !== 0 ? Math.abs(avgWin / avgLoss) : totalPnl > 0 ? Infinity : 0;

    // Streaks
    let currentStreak = 0, bestStreak = 0, worstStreak = 0, streak = 0;
    for (const t of closed) {
      if ((t.pnl || 0) > 0) {
        streak = streak > 0 ? streak + 1 : 1;
        bestStreak = Math.max(bestStreak, streak);
      } else {
        streak = streak < 0 ? streak - 1 : -1;
        worstStreak = Math.min(worstStreak, streak);
      }
    }
    currentStreak = streak;

    return {
      enabled: this.enabled,
      mode: this.mode,
      symbol: this.symbol,
      capital: this.capital,
      positions: Array.from(this.positions.values()),
      closedTrades: closed.slice(-50),
      stats: {
        totalTrades: closed.length,
        winningTrades: winning.length,
        losingTrades: losing.length,
        winRate,
        totalPnl,
        totalFees,
        profitFactor,
        maxDrawdown: this.maxDrawdown,
        maxDrawdownPercent: this.maxDrawdownPercent,
        avgWin,
        avgLoss,
        sharpeRatio: 0,
        currentStreak,
        bestStreak,
        worstStreak
      }
    };
  }

  /**
   * Reset all trading state
   */
  reset(): void {
    this.positions.clear();
    this.closedTrades = [];
    this.capital = this.baseCapital;
    this.peakBalance = this.baseCapital;
    this.maxDrawdown = 0;
    this.maxDrawdownPercent = 0;
  }

  /**
   * Get current status summary for dashboard
   */
  getStatus(): any {
    return {
      enabled: this.enabled,
      mode: this.mode,
      testMode: this.testMode,
      symbol: this.symbol,
      capital: this.capital,
      equity: this.getTotalEquity(),
      unrealizedPnl: this.getUnrealizedPnL(),
      hasPosition: this.positions.size > 0,
      currentPrice: this.currentPrice,
      stopLossPct: this.stopLossPercent,
      takeProfitPct: this.takeProfitPercent,
      positionSize: this.positionSize
    };
  }
}

export default LiveTrader;
